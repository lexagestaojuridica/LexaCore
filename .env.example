# =============================================================================
# LEXA v3.5 - Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores reais
# NUNCA comite .env.local no repositório
# =============================================================================

# =============================================================================
# CLERK - Autenticação & Gestão de Usuários/Organizações
# https://dashboard.clerk.com
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_SEU_PUBLISHABLE_KEY_AQUI
CLERK_SECRET_KEY=sk_test_SEU_SECRET_KEY_AQUI
CLERK_WEBHOOK_SECRET=whsec_SEU_WEBHOOK_SECRET_AQUI

# Clerk URLs (padrão para Next.js App Router)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# =============================================================================
# SUPABASE - PostgreSQL + RLS + Storage + Realtime
# https://app.supabase.com
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_SUPABASE_PROJECT_ID=SEU_PROJECT_ID

# Service Role Key (apenas para Edge Functions e scripts de admin - NUNCA expor no client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# ASAAS - Gateway de Pagamento
# https://www.asaas.com
# =============================================================================
ASAAS_API_KEY=SEU_ASAAS_API_KEY_AQUI
# Ambiente: 'sandbox' para testes, 'production' para produção
ASAAS_ENVIRONMENT=sandbox
ASAAS_BASE_URL_SANDBOX=https://sandbox.asaas.com/api/v3
ASAAS_BASE_URL_PRODUCTION=https://api.asaas.com/v3

# =============================================================================
# APP
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LEXA
NODE_ENV=development
